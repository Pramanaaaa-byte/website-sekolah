<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 180" width="180" height="180">
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#64748b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#475569;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background with rounded corners -->
  <rect width="180" height="180" rx="40" fill="url(#grad)"/>
  
  <!-- Graduation cap centered -->
  <g transform="translate(90, 90)">
    <!-- Cap base -->
    <path d="M -45 11 L 0 -11 L 45 11 L 0 33 Z" fill="#fff" opacity="0.95"/>
    <!-- Cap top with depth -->
    <path d="M -45 11 L 0 -11 L 45 11 L 0 33 Z" fill="none" stroke="#fff" stroke-width="2"/>
    <!-- Tassel -->
    <line x1="0" y1="-11" x2="0" y2="-35" stroke="#fff" stroke-width="6" stroke-linecap="round"/>
    <circle cx="0" cy="-35" r="8" fill="#fff"/>
    <!-- Tassel string -->
    <path d="M 0 -35 Q 15 -25 20 -15" stroke="#fff" stroke-width="3" fill="none" stroke-linecap="round"/>
  </g>
  
  <!-- Decorative elements -->
  <circle cx="45" cy="45" r="6" fill="#fff" opacity="0.6"/>
  <circle cx="135" cy="45" r="6" fill="#fff" opacity="0.6"/>
  <circle cx="45" cy="135" r="6" fill="#fff" opacity="0.6"/>
  <circle cx="135" cy="135" r="6" fill="#fff" opacity="0.6"/>
</svg>
